# ============================================================
# WEB PUSH NOTIFICATIONS - Environment Variables
# ============================================================

# VAPID Public Key (accessible di client-side)
# Generate using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BK...your-public-key-here

# VAPID Private Key (server-only, KEEP SECRET!)
VAPID_PRIVATE_KEY=your-private-key-here

# VAPID Contact Email (untuk server push service)
VAPID_EMAIL=mailto:admin@yourapp.com

# ============================================================
# INSTRUCTIONS
# ============================================================

# 1. Generate VAPID keys:
#    npx web-push generate-vapid-keys

# 2. Copy public key ke NEXT_PUBLIC_VAPID_PUBLIC_KEY
# 3. Copy private key ke VAPID_PRIVATE_KEY
# 4. Set your contact email di VAPID_EMAIL

# ⚠️ IMPORTANT:
# - NEVER commit .env.local to Git
# - Public key is safe to expose (used in client)
# - Private key MUST stay secret (used in server)

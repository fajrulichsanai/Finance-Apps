# Test Environment Configuration
# Copy this file to .env.test.local and fill with your test credentials

# Base URL
BASE_URL=http://localhost:3000

# Valid Test User Credentials
TEST_EMAIL=projectichsankamil@gmail.com
TEST_PASSWORD=123123123

# Invalid Test Credentials (for negative test cases)
INVALID_EMAIL=notexist@example.com
INVALID_PASSWORD=WrongPassword123!

# SQL Injection Test String
SQL_INJECTION_STRING=' OR '1'='1

# Test User with Whitespace
TEST_EMAIL_WITH_SPACES=  projectichsankamil@gmail.com  

# Headless Mode (true for CI, false for UI testing)
HEADLESS=false
